#!/usr/bin/env python3

# etch - Edit PDF metadata


from pathlib import Path
import argparse
import json
import shutil
import subprocess
import sys


METADATA_TAGS = [
    "-FileName",
    "-Title",
    "-Author"
]


def start_app():
    """Edit PDF metadata."""

    if not shutil.which("exiftool"):
        print("Unable to find exiftool. Is it installed?")
        sys.exit(1)

    args = get_args()

    metadata = get_metadata(Path(args.file))
    if metadata is None:
        sys.exit(1)

    if args.title is None and args.author is None:
        print_metadata(metadata)
    else:
        print("Before:")
        print_metadata(metadata)

        print()
        print("After:")
        print_metadata(preview_metadata(metadata, args.title, args.author))

        print()
        print("Apply changes? [y/n] ", end="", flush=True)
        if input().strip().lower() != "y":
            print("No changes made.")
            sys.exit()

        if set_metadata(Path(args.file), args.title, args.author):
            print("Done.")


def get_args():
    """Configure argument parser including help text.

    Returns:
        Parsed arguments namespace
    """

    parser = argparse.ArgumentParser(
        description="etch - edit pdf metadata",
        epilog="https://github.com/idianal/toys-python/etch")

    parser.add_argument("file", help="path to pdf")
    parser.add_argument("--title", help="set title metadata")
    parser.add_argument("--author", help="set author metadata")

    return parser.parse_args()


def get_metadata(pdf_path):
    """Get metadata from a PDF.

    Arguments:
        pdf_path - Path to the PDF

    Returns:
        Dict of metadata, or None on error
    """

    if not pdf_path.exists():
        print("File not found: " + str(pdf_path))
        return None

    if pdf_path.suffix.lower() != ".pdf":
        print("Not a PDF: " + str(pdf_path))
        return None

    result = subprocess.run(
        ["exiftool", "-j"] + METADATA_TAGS + [str(pdf_path)],
        capture_output=True,
        text=True)

    if result.returncode != 0:
        print("Error reading metadata: " + result.stderr.strip())
        return None

    return json.loads(result.stdout)[0]


def set_metadata(pdf_path, title, author):
    """Write title and/or author metadata to a PDF.

    Arguments:
        pdf_path - Path to the PDF
        title    - New title value, or None to leave unchanged
        author   - New author value, or None to leave unchanged

    Returns:
        True on success, False on error
    """

    command = ["exiftool", "-overwrite_original"]

    if title is not None:
        command.append("-Title=" + title)

    if author is not None:
        command.append("-Author=" + author)

    command.append(str(pdf_path))
    result = subprocess.run(command, capture_output=True, text=True)

    if result.returncode != 0:
        print("Error writing metadata: " + result.stderr.strip())
        return False

    return True


def preview_metadata(metadata, title, author):
    """Return a copy of metadata with proposed edits applied (without writing).

    Arguments:
        metadata - Dict of current metadata from exiftool
        title    - Proposed title value, or None to leave unchanged
        author   - Proposed author value, or None to leave unchanged

    Returns:
        Dict of metadata reflecting the proposed changes
    """

    preview = dict(metadata)

    if title is not None:
        preview["Title"] = title

    if author is not None:
        preview["Author"] = author

    return preview


def print_metadata(metadata):
    """Print file name, title, and author from metadata.

    Arguments:
        metadata - Dict of metadata from exiftool
    """

    print("File Name : " + metadata.get("FileName", "-"))
    print("Title     : " + metadata.get("Title", "-"))
    print("Author    : " + metadata.get("Author", "-"))


if __name__ == "__main__":
    start_app()
